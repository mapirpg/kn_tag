generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tag {
  id              String     @id @default(uuid())
  name            String
  publicKey       String     @unique
  privateKey      String
  hashedPublicKey String     @unique
  createdAt       DateTime   @default(now())
  locations       Location[]
}

model Location {
  id        String   @id @default(uuid())
  tagId     String
  latitude  Float
  longitude Float
  accuracy  Float
  timestamp DateTime
  payload   String?
  createdAt DateTime @default(now())
  tag       Tag      @relation(fields: [tagId], references: [id])
}
